# Frontend Environment Configuration
# Copy this to .env.development.local or use during build

# API Endpoint - Where the backend is running
VITE_API_URL=http://localhost:8080

# Application Name (displayed in UI)
VITE_APP_NAME=AntreIn

# Feature Flags
VITE_ENABLE_TTS=true

# Build Options
VITE_SOURCE_MAP=true  # Set to false in production

# Development Server
VITE_DEV_PORT=5173
